# Production Environment Configuration
# Copy this to .env.prod and fill with your production values

# ============================================================
# REQUIRED - PRODUCTION SETTINGS
# ============================================================

# Telegram Bot Token
BOT_TOKEN=your_production_bot_token

# Public URL - your domain through Cloudflare Tunnel
# Example: https://bot.yourdomain.com
PUBLIC_URL=https://your-domain.com

# ============================================================
# OPTIONAL - PRODUCTION SETTINGS
# ============================================================

# Server Configuration (internal)
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Admin User IDs (comma-separated)
ADMIN_IDS=your_telegram_user_id

# HDRezka Configuration
REZKA_MIRROR=https://hdrezka-home.tv
REZKA_TIMEOUT=30
REZKA_MAX_RETRIES=3

# Proxy for HDRezka (optional, if mirror blocked on VPS)
# REZKA_PROXY_URL=socks5://proxy:1080

# Cache Configuration
CACHE_ENABLED=true
CACHE_BACKEND=sqlite
CACHE_SQLITE_PATH=/app/data/cache.db
